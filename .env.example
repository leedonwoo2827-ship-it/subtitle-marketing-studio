# Optional operational defaults. GUI settings in data/user_settings.json take precedence.

# LiteLLM proxy provider
LITELLM_BASE_URL=https://api.deepseek.com
LITELLM_API_KEY=
LITELLM_MODEL=deepseek/deepseek-chat

# Ollama local provider
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Streamlit port (avoid conflict with tsbookmaker 8610)
STREAMLIT_SERVER_PORT=8620
