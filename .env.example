# Ubion LiteLLM proxy. GUI settings in data/user_settings.json take precedence.
UBION_LITELLM_URL=http://192.168.50.119:4000
UBION_LITELLM_KEY=

# Image generation (Nano Banana by default). Leave URL/KEY empty to reuse
# UBION_LITELLM_URL / KEY above. Useful when pointing image cards at a
# local model server (Stable Diffusion / ComfyUI / etc.).
UBION_IMAGE_URL=
UBION_IMAGE_KEY=
UBION_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Streamlit port
STREAMLIT_SERVER_PORT=8620
